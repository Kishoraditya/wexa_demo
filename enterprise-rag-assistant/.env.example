# ============================================================
# Environment Variables — Copy to .env and fill in values
# NEVER commit .env to the repository
# ============================================================

# OpenAI — used for embeddings and fallback generation
OPENAI_API_KEY=sk-...

# Pinecone — vector store
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1-aws    # check your Pinecone console

# HuggingFace — for loading fine-tuned adapter
HUGGINGFACE_TOKEN=hf_...              # required if adapter repo is private

# Application environment
ENVIRONMENT=development               # development | staging | production

# Optional: override config.yaml values at runtime
# LOG_LEVEL=DEBUG
# CACHE_ENABLED=false